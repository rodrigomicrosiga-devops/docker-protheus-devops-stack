# Variáveis Globais de Ambiente
ENV_NAME=protheus_dev

# Governança de Infraestrutura (Novas Variáveis)
DBACCESS_PORT=7890
DBACCESS_SERVER=protheus_dbaccess
LICENSE_SERVER=protheus_license
LICENSE_SERVER_PORT=5555

# Configurações de Portas Multiprotocolo (TCP/WebApp)
CORE_PORT_MULTI=1234
REST_PORT_MULTI=1235
TELNET_PORT_MULTI=1236

# Portas Especialistas de Serviços Dedicados
APP_MONITOR_PORT=32033
TELNET_PORT=23

# Parametrização Dedicada do Barramento REST API
REST_HTTP_PORT=8400
REST_URI=/rest
REST_PREP_ENV=99,01
REST_INSTANCES=1,1